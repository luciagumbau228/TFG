&ACCESS R
&COMMENT Collision monitoring library
DEF CollMonLib()
END


DEFFCT BOOL DATASET_IDX_VALID(IDX:IN)
   INT IDX
   RETURN ((IDX > 0) AND (IDX < (NUM_COLLMON_SETTINGS + 1)))
ENDFCT


DEFFCT BOOL AXIS_IDX_VALID(IDX:IN)
   INT IDX
   RETURN ((IDX > 0) AND (IDX < 13))
ENDFCT


GLOBAL DEF SET_DATASET_METHOD(DATASET_IDX:IN, METHOD:IN)
   INT DATASET_IDX
   INT METHOD
   ; Check dataset index validity
   IF NOT DATASET_IDX_VALID(DATASET_IDX) THEN
      RETURN
   ENDIF
   SWITCH METHOD
      CASE 0
         COLLMON_DATESET_METHOD[DATASET_IDX]=#INITIAL
      CASE 1
         COLLMON_DATESET_METHOD[DATASET_IDX]=#MANUAL
      CASE 2
         COLLMON_DATESET_METHOD[DATASET_IDX]=#LEARN
      DEFAULT
         RETURN
   ENDSWITCH
END


GLOBAL DEF SET_DATASET_MODIFY_TS(DATASET_IDX:IN, DATE_INPUT:IN)
   INT DATASET_IDX
   DECL DATE DATE_INPUT
   CHAR TEMP_TIMESTAMP[40]
   DECL STATE_T SWRITE_STATE
   INT SWRITE_OFFSET
   BOOL STRCPY_RESULT
   ; Check dataset index validity
   IF NOT DATASET_IDX_VALID(DATASET_IDX) THEN
      RETURN
   ENDIF
   ; Initialize local variables
   SWRITE_OFFSET=0
   TEMP_TIMESTAMP[]=" "
   ; Align to required format
   Swrite(TEMP_TIMESTAMP[], SWRITE_STATE, SWRITE_OFFSET, "%0.4d-%0.2d-%0.2dT%0.2d:%0.2d:%0.2d.000Z", DATE_INPUT.YEAR, DATE_INPUT.MONTH, DATE_INPUT.DAY, DATE_INPUT.HOUR, DATE_INPUT.MIN, DATE_INPUT.SEC)
   ; Set actual timestamp
   STRCPY_RESULT=STRCOPY(COLLMON_MODIFY_TIMESTAMP[DATASET_IDX,], TEMP_TIMESTAMP[])
END


GLOBAL DEF SET_CM_PRO_AXIS_ENABLE(DATASET_IDX:IN, AXIS_IDX:IN, ENABLE:IN)
   INT DATASET_IDX
   INT AXIS_IDX
   BOOL ENABLE
   ; Check dataset and axis index validity
   IF NOT (DATASET_IDX_VALID(DATASET_IDX) AND AXIS_IDX_VALID(AXIS_IDX)) THEN
      RETURN
   ENDIF
   COLLMON_AXIS_ENABLE_PRO[DATASET_IDX,AXIS_IDX]=ENABLE
END


GLOBAL DEFFCT BOOL IS_CM_PRO_AXIS_ENABLED(DATASET_IDX:IN, AXIS_IDX:IN)
   INT DATASET_IDX
   INT AXIS_IDX
   ; Check dataset and axis index validity
   IF NOT (DATASET_IDX_VALID(DATASET_IDX) AND AXIS_IDX_VALID(AXIS_IDX)) THEN
      RETURN FALSE
   ENDIF
   RETURN COLLMON_AXIS_ENABLE_PRO[DATASET_IDX,AXIS_IDX]
ENDFCT


GLOBAL DEF SET_CM_PRO_VALUES(CM_AX1:IN, CM_AX2:IN, CM_AX3:IN, CM_AX4:IN, CM_AX5:IN, CM_AX6:IN)
   INT TEST
   INT CM_AX1
   INT CM_AX2
   INT CM_AX3
   INT CM_AX4
   INT CM_AX5
   INT CM_AX6
   ON_ERROR_PROCEED
   TEST=CM_AX1
   IF $ERR.NUMBER == 0 THEN
      $COLLMON_TOL_PRO[1]=CM_AX1
   ENDIF
   ON_ERROR_PROCEED
   TEST=CM_AX2
   IF $ERR.NUMBER == 0 THEN
      $COLLMON_TOL_PRO[2]=CM_AX2
   ENDIF
   ON_ERROR_PROCEED
   TEST=CM_AX3
   IF $ERR.NUMBER == 0 THEN
      $COLLMON_TOL_PRO[3]=CM_AX3
   ENDIF
   ON_ERROR_PROCEED
   TEST=CM_AX4
   IF $ERR.NUMBER == 0 THEN
      $COLLMON_TOL_PRO[4]=CM_AX4
   ENDIF
   ON_ERROR_PROCEED
   TEST=CM_AX5
   IF $ERR.NUMBER == 0 THEN
      $COLLMON_TOL_PRO[5]=CM_AX5
   ENDIF
   ON_ERROR_PROCEED
   TEST=CM_AX6
   IF $ERR.NUMBER == 0 THEN
      $COLLMON_TOL_PRO[6]=CM_AX6
   ENDIF
   ERR_CLEAR($ERR)
   $COLLMON_IDX=0
END


GLOBAL DEF SET_CM_PRO_DEFAULT()
   INT I
   FOR I = 1 TO 12
      $COLLMON_TOL_PRO[I]=$COLLMON_TOL_PRO_DEF[I]
   ENDFOR
   $COLLMON_IDX=0
END


GLOBAL DEF SET_CM_PRO_INACTIVE()
   INT I
   INT GLOBAL_CD_LIMIT[12]
   IF $IMPROVED_COLLMON == TRUE THEN
      GET_CM_GLOBAL_LIMIT(GLOBAL_CD_LIMIT[])
      FOR I = 1 TO 12
         IF (COLLMON_TOL_PRO[I] < 0) THEN ;no global COLLMON_TOL_PRO[I] exists
            IF ($COLLMON_GLOBAL_SUPPORT == TRUE) AND (GLOBAL_CD_LIMIT_TYPE <> #OFF) THEN ;Set global axis limit
               $COLLMON_TOL_PRO[I]=GLOBAL_CD_LIMIT[I]
            ELSE
               $COLLMON_TOL_PRO[I]=0
            ENDIF
            $COLLMON_IDX=0
         ELSE
            $COLLMON_TOL_PRO[I]=COLLMON_TOL_PRO[I] ;sets $COLLMON_TOL_PRO[I] from global
            $COLLMON_IDX=COLLMON_IDX
         ENDIF
      ENDFOR
   ELSE
      FOR I = 1 TO 12
         $COLLMON_TOL_PRO[I]=0
      ENDFOR
   ENDIF
END

GLOBAL DEF GET_CM_GLOBAL_LIMIT(GLOBAL_LIMIT[]:OUT)
   INT GLOBAL_LIMIT[]
   IF (GLOBAL_CD_LIMIT_TYPE == #PRESETS) THEN
      GLOBAL_LIMIT[1]=GLOBAL_PRESETS_VALUE
      GLOBAL_LIMIT[2]=GLOBAL_PRESETS_VALUE
      GLOBAL_LIMIT[3]=GLOBAL_PRESETS_VALUE
      GLOBAL_LIMIT[4]=GLOBAL_PRESETS_VALUE
      GLOBAL_LIMIT[5]=GLOBAL_PRESETS_VALUE
      GLOBAL_LIMIT[6]=GLOBAL_PRESETS_VALUE
      GLOBAL_LIMIT[7]=GLOBAL_PRESETS_VALUE
      GLOBAL_LIMIT[8]=GLOBAL_PRESETS_VALUE
      GLOBAL_LIMIT[9]=GLOBAL_PRESETS_VALUE
      GLOBAL_LIMIT[10]=GLOBAL_PRESETS_VALUE
      GLOBAL_LIMIT[11]=GLOBAL_PRESETS_VALUE
      GLOBAL_LIMIT[12]=GLOBAL_PRESETS_VALUE
   ELSE ;#CUSTOM
      GLOBAL_LIMIT[1]=GLOBAL_CUSTOM_VALUE[1]
      GLOBAL_LIMIT[2]=GLOBAL_CUSTOM_VALUE[2]
      GLOBAL_LIMIT[3]=GLOBAL_CUSTOM_VALUE[3]
      GLOBAL_LIMIT[4]=GLOBAL_CUSTOM_VALUE[4]
      GLOBAL_LIMIT[5]=GLOBAL_CUSTOM_VALUE[5]
      GLOBAL_LIMIT[6]=GLOBAL_CUSTOM_VALUE[6]
      GLOBAL_LIMIT[7]=GLOBAL_CUSTOM_VALUE[7]
      GLOBAL_LIMIT[8]=GLOBAL_CUSTOM_VALUE[8]
      GLOBAL_LIMIT[9]=GLOBAL_CUSTOM_VALUE[9]
      GLOBAL_LIMIT[10]=GLOBAL_CUSTOM_VALUE[10]
      GLOBAL_LIMIT[11]=GLOBAL_CUSTOM_VALUE[11]
      GLOBAL_LIMIT[12]=GLOBAL_CUSTOM_VALUE[12]
   ENDIF
END


GLOBAL DEF RESET_CM_MAX()
   INT I
   FOR I = 1 TO 12
      $COLLMON_MAX[I]=0
   ENDFOR
END


GLOBAL DEF SAVE_CM_PRO_SETTING(SETTING_IDX:IN)
   INT SETTING_IDX
   INT I
   FOR I = 1 TO 12
      COLLMON_SETTING[SETTING_IDX,I]=$COLLMON_TOL_PRO[I]
   ENDFOR
END


GLOBAL DEF SAVE_CM_COM_SETTING(SETTING_IDX:IN)
   INT SETTING_IDX
   INT I
   FOR I = 1 TO 12
      COLLMON_SETTING[SETTING_IDX,I]=$COLLMON_TOL_COM[I]
   ENDFOR
END


GLOBAL DEF READ_CM_SETTING(SETTING_IDX:IN, VALUES[]:OUT)
   INT SETTING_IDX
   INT VALUES[]
   INT I
   ; Check dataset index validity
   IF NOT DATASET_IDX_VALID(SETTING_IDX) THEN
      RETURN
   ENDIF
   FOR I = 1 TO 12
      VALUES[I]=COLLMON_SETTING[SETTING_IDX,I]
   ENDFOR
END


GLOBAL DEF READ_CM_DISPLAYED(SETTING_IDX:IN, VALUES[]:OUT)
   INT SETTING_IDX
   INT VALUES[]
   INT I
   ; Check dataset index validity
   IF NOT DATASET_IDX_VALID(SETTING_IDX) THEN
      RETURN
   ENDIF
   FOR I = 1 TO 12
      VALUES[I]=COLLMON_DISPLAYED[SETTING_IDX,I]
   ENDFOR
END


GLOBAL DEF WRITE_CM_SETTING(SETTING_IDX:IN, VALUES[]:OUT)
   INT SETTING_IDX
   INT VALUES[]
   INT I
   ; Check dataset index validity
   IF NOT DATASET_IDX_VALID(SETTING_IDX) THEN
      RETURN
   ENDIF
   FOR I = 1 TO 12
      IF (VALUES[I] < 0) THEN
         COLLMON_SETTING[SETTING_IDX,I]=0
      ELSE
         IF VALUES[I] > 500 THEN
            COLLMON_SETTING[SETTING_IDX,I]=500
         ELSE
            COLLMON_SETTING[SETTING_IDX,I]=VALUES[I]
         ENDIF
      ENDIF
   ENDFOR
END


GLOBAL DEF WRITE_CM_SETTING_DISPL(SETTING_IDX:IN, VALUES[]:OUT)
   INT SETTING_IDX
   INT VALUES[]
   INT I
   ; Check dataset index validity
   IF NOT DATASET_IDX_VALID(SETTING_IDX) THEN
      RETURN
   ENDIF
   FOR I = 1 TO 12
      IF (VALUES[I] < 0) THEN
         COLLMON_SETTING[SETTING_IDX,I]=0
         ; Set displayed values, too
         COLLMON_DISPLAYED[SETTING_IDX,I]=0
      ELSE
         IF VALUES[I] > 500 THEN
            COLLMON_SETTING[SETTING_IDX,I]=500
            ; Set displayed values, too
            COLLMON_DISPLAYED[SETTING_IDX,I]=500
         ELSE
            COLLMON_SETTING[SETTING_IDX,I]=VALUES[I]
            ; Set displayed values, too
            COLLMON_DISPLAYED[SETTING_IDX,I]=VALUES[I]
         ENDIF
      ENDIF
   ENDFOR
END


GLOBAL DEF SAVE_CM_MAX_SETTING(SETTING_IDX:IN, OFFSET:IN)
   INT SETTING_IDX
   INT OFFSET
   INT TEST, OFFSET_WERT, I
   DECL INT SET_VALUES[12]
   ; Vorbelegung mit Default-Wert 0
   OFFSET_WERT=0
   ON_ERROR_PROCEED
   TEST=OFFSET
   IF $ERR.NUMBER == 0 THEN
      OFFSET_WERT=OFFSET ; Parameter verwenden
   ENDIF
   GET_COLLMON_SET(SETTING_IDX, SET_VALUES[])
   FOR I = 1 TO 12
      ; durch Lernfahrt will man auskeschaltete Achsen nicht einschalten
      IF COLLMON_SETTING[SETTING_IDX,I] <> 0 THEN
         COLLMON_SETTING[SETTING_IDX,I]=SET_VALUES[I] + OFFSET_WERT
      ENDIF
   ENDFOR
   ERR_CLEAR($ERR)
END


GLOBAL DEF USE_CM_PRO_SETTING(SETTING_IDX:IN)
   INT SETTING_IDX
   INT I
   FOR I = 1 TO 12
      $COLLMON_TOL_PRO[I]=COLLMON_SETTING[SETTING_IDX,I]
   ENDFOR
   $COLLMON_IDX=SETTING_IDX
END


GLOBAL DEF INIT_CM_SETTINGS()
   INT I, J
   FOR I = 1 TO NUM_COLLMON_SETTINGS
      FOR J = 1 TO 12
         COLLMON_SETTING[I,J]=100
      ENDFOR
   ENDFOR
END


GLOBAL DEF SET_CD_PARAMS(Index:IN)
   DECL INT Index
   IF (Index > 0) AND (Index < 31) THEN
      USE_CM_PRO_SETTING(Index)
   ELSE
      SET_CM_PRO_INACTIVE()
   ENDIF
END


GLOBAL DEF USE_CD_PARAMS(Index:IN)
   DECL INT Index
   DECL INT I
   IF (Index > 0) AND (Index < 31) THEN
      FOR I = 1 TO 12
         IF (COLLMON_AXIS_ENABLE_PRO[Index,I]) THEN
            COLLMON_TOL_PRO[I]=COLLMON_SETTING[Index,I] ; saves COLLMON_TOL_PRO for global using
         ELSE
            COLLMON_TOL_PRO[I]=0
         ENDIF
      ENDFOR
      COLLMON_IDX=Index
      USE_CM_PRO_SETTING(Index)
   ELSE
      FOR I = 1 TO 12
         COLLMON_TOL_PRO[I]=-1 ; saves COLLMON_TOL_PRO for global using
      ENDFOR
      COLLMON_IDX=-1
      SET_CM_PRO_INACTIVE()
   ENDIF
END


GLOBAL DEF RESET_CD_PARAMS()
   DECL INT I
   FOR I = 1 TO 12
      COLLMON_TOL_PRO[I]=-1 ; resets COLLMON_TOL_PRO for global using
   ENDFOR
   COLLMON_IDX=-1
END


GLOBAL DEFFCT INT USE_CM_PRO_VALUES(SETTING_IDX:IN)
   INT SETTING_IDX
   IF (SETTING_IDX == -1) THEN ;Force deactivation
      $COLLMON_TOL_PRO[2]=0
      $COLLMON_TOL_PRO[3]=0
      $COLLMON_TOL_PRO[4]=0
      $COLLMON_TOL_PRO[5]=0
      $COLLMON_TOL_PRO[6]=0
      $COLLMON_TOL_PRO[7]=0
      $COLLMON_TOL_PRO[8]=0
      $COLLMON_TOL_PRO[9]=0
      $COLLMON_TOL_PRO[10]=0
      $COLLMON_TOL_PRO[11]=0
      $COLLMON_TOL_PRO[12]=0
      $COLLMON_IDX=0
      RETURN 0
   ENDIF
   IF (SETTING_IDX > 0) AND (SETTING_IDX < 31) THEN
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,2]) THEN
         $COLLMON_TOL_PRO[2]=COLLMON_SETTING[SETTING_IDX,2]
      ELSE
         $COLLMON_TOL_PRO[2]=0
      ENDIF
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,3]) THEN
         $COLLMON_TOL_PRO[3]=COLLMON_SETTING[SETTING_IDX,3]
      ELSE
         $COLLMON_TOL_PRO[3]=0
      ENDIF
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,4]) THEN
         $COLLMON_TOL_PRO[4]=COLLMON_SETTING[SETTING_IDX,4]
      ELSE
         $COLLMON_TOL_PRO[4]=0
      ENDIF
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,5]) THEN
         $COLLMON_TOL_PRO[5]=COLLMON_SETTING[SETTING_IDX,5]
      ELSE
         $COLLMON_TOL_PRO[5]=0
      ENDIF
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,6]) THEN
         $COLLMON_TOL_PRO[6]=COLLMON_SETTING[SETTING_IDX,6]
      ELSE
         $COLLMON_TOL_PRO[6]=0
      ENDIF
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,7]) THEN
         $COLLMON_TOL_PRO[7]=COLLMON_SETTING[SETTING_IDX,7]
      ELSE
         $COLLMON_TOL_PRO[7]=0
      ENDIF
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,8]) THEN
         $COLLMON_TOL_PRO[8]=COLLMON_SETTING[SETTING_IDX,8]
      ELSE
         $COLLMON_TOL_PRO[8]=0
      ENDIF
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,9]) THEN
         $COLLMON_TOL_PRO[9]=COLLMON_SETTING[SETTING_IDX,9]
      ELSE
         $COLLMON_TOL_PRO[9]=0
      ENDIF
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,10]) THEN
         $COLLMON_TOL_PRO[10]=COLLMON_SETTING[SETTING_IDX,10]
      ELSE
         $COLLMON_TOL_PRO[10]=0
      ENDIF
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,11]) THEN
         $COLLMON_TOL_PRO[11]=COLLMON_SETTING[SETTING_IDX,11]
      ELSE
         $COLLMON_TOL_PRO[11]=0
      ENDIF
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,12]) THEN
         $COLLMON_TOL_PRO[12]=COLLMON_SETTING[SETTING_IDX,12]
      ELSE
         $COLLMON_TOL_PRO[12]=0
      ENDIF
      $COLLMON_IDX=SETTING_IDX
      IF (COLLMON_AXIS_ENABLE_PRO[SETTING_IDX,1]) THEN
         RETURN COLLMON_SETTING[SETTING_IDX,1]
      ELSE
         RETURN 0
      ENDIF
   ELSE
      IF (COLLMON_TOL_PRO[1] < 0) THEN ;no global COLLMON_TOL_PRO[I] exists
         IF ($COLLMON_GLOBAL_SUPPORT == TRUE) AND (GLOBAL_CD_LIMIT_TYPE <> #OFF) THEN ;Set global axis limit
            IF (GLOBAL_CD_LIMIT_TYPE == #PRESETS) THEN
               $COLLMON_TOL_PRO[2]=GLOBAL_PRESETS_VALUE
               $COLLMON_TOL_PRO[3]=GLOBAL_PRESETS_VALUE
               $COLLMON_TOL_PRO[4]=GLOBAL_PRESETS_VALUE
               $COLLMON_TOL_PRO[5]=GLOBAL_PRESETS_VALUE
               $COLLMON_TOL_PRO[6]=GLOBAL_PRESETS_VALUE
               $COLLMON_TOL_PRO[7]=GLOBAL_PRESETS_VALUE
               $COLLMON_TOL_PRO[8]=GLOBAL_PRESETS_VALUE
               $COLLMON_TOL_PRO[9]=GLOBAL_PRESETS_VALUE
               $COLLMON_TOL_PRO[10]=GLOBAL_PRESETS_VALUE
               $COLLMON_TOL_PRO[11]=GLOBAL_PRESETS_VALUE
               $COLLMON_TOL_PRO[12]=GLOBAL_PRESETS_VALUE
               $COLLMON_IDX=0
               RETURN GLOBAL_PRESETS_VALUE
            ELSE ;#CUSTOM
               $COLLMON_TOL_PRO[2]=GLOBAL_CUSTOM_VALUE[2]
               $COLLMON_TOL_PRO[3]=GLOBAL_CUSTOM_VALUE[3]
               $COLLMON_TOL_PRO[4]=GLOBAL_CUSTOM_VALUE[4]
               $COLLMON_TOL_PRO[5]=GLOBAL_CUSTOM_VALUE[5]
               $COLLMON_TOL_PRO[6]=GLOBAL_CUSTOM_VALUE[6]
               $COLLMON_TOL_PRO[7]=GLOBAL_CUSTOM_VALUE[7]
               $COLLMON_TOL_PRO[8]=GLOBAL_CUSTOM_VALUE[8]
               $COLLMON_TOL_PRO[9]=GLOBAL_CUSTOM_VALUE[9]
               $COLLMON_TOL_PRO[10]=GLOBAL_CUSTOM_VALUE[10]
               $COLLMON_TOL_PRO[11]=GLOBAL_CUSTOM_VALUE[11]
               $COLLMON_TOL_PRO[12]=GLOBAL_CUSTOM_VALUE[12]
               $COLLMON_IDX=0
               RETURN GLOBAL_CUSTOM_VALUE[1]
            ENDIF
         ELSE
            $COLLMON_TOL_PRO[2]=0
            $COLLMON_TOL_PRO[3]=0
            $COLLMON_TOL_PRO[4]=0
            $COLLMON_TOL_PRO[5]=0
            $COLLMON_TOL_PRO[6]=0
            $COLLMON_TOL_PRO[7]=0
            $COLLMON_TOL_PRO[8]=0
            $COLLMON_TOL_PRO[9]=0
            $COLLMON_TOL_PRO[10]=0
            $COLLMON_TOL_PRO[11]=0
            $COLLMON_TOL_PRO[12]=0
            $COLLMON_IDX=0
            RETURN 0
         ENDIF
      ELSE
         $COLLMON_TOL_PRO[2]=COLLMON_TOL_PRO[2] ;sets $COLLMON_TOL_PRO[I] from global
         $COLLMON_TOL_PRO[3]=COLLMON_TOL_PRO[3] ;sets $COLLMON_TOL_PRO[I] from global
         $COLLMON_TOL_PRO[4]=COLLMON_TOL_PRO[4] ;sets $COLLMON_TOL_PRO[I] from global
         $COLLMON_TOL_PRO[5]=COLLMON_TOL_PRO[5] ;sets $COLLMON_TOL_PRO[I] from global
         $COLLMON_TOL_PRO[6]=COLLMON_TOL_PRO[6] ;sets $COLLMON_TOL_PRO[I] from global
         IF (COLLMON_TOL_PRO[7] > -1) THEN
            $COLLMON_TOL_PRO[7]=COLLMON_TOL_PRO[7] ;sets $COLLMON_TOL_PRO[I] from global
         ELSE
            $COLLMON_TOL_PRO[7]=0
         ENDIF
         IF (COLLMON_TOL_PRO[8] > -1) THEN
            $COLLMON_TOL_PRO[8]=COLLMON_TOL_PRO[8] ;sets $COLLMON_TOL_PRO[I] from global
         ELSE
            $COLLMON_TOL_PRO[8]=0
         ENDIF
         IF (COLLMON_TOL_PRO[9] > -1) THEN
            $COLLMON_TOL_PRO[9]=COLLMON_TOL_PRO[9] ;sets $COLLMON_TOL_PRO[I] from global
         ELSE
            $COLLMON_TOL_PRO[9]=0
         ENDIF
         IF (COLLMON_TOL_PRO[10] > -1) THEN
            $COLLMON_TOL_PRO[10]=COLLMON_TOL_PRO[10] ;sets $COLLMON_TOL_PRO[I] from global
         ELSE
            $COLLMON_TOL_PRO[10]=0
         ENDIF
         IF (COLLMON_TOL_PRO[11] > -1) THEN
            $COLLMON_TOL_PRO[11]=COLLMON_TOL_PRO[11] ;sets $COLLMON_TOL_PRO[I] from global
         ELSE
            $COLLMON_TOL_PRO[11]=0
         ENDIF
         IF (COLLMON_TOL_PRO[12] > -1) THEN
            $COLLMON_TOL_PRO[12]=COLLMON_TOL_PRO[12] ;sets $COLLMON_TOL_PRO[I] from global
         ELSE
            $COLLMON_TOL_PRO[12]=0
         ENDIF
         $COLLMON_IDX=COLLMON_IDX
         RETURN COLLMON_TOL_PRO[1] ;returns $COLLMON_TOL_PRO[I] from global      
      ENDIF
   ENDIF
ENDFCT


GLOBAL DEF SET_TQ_VALUES(TQ_AX1:IN, TQ_AX2:IN, TQ_AX3:IN, TQ_AX4:IN, TQ_AX5:IN, TQ_AX6:IN)
   INT I
   INT TQ_AX1
   INT TQ_AX2
   INT TQ_AX3
   INT TQ_AX4
   INT TQ_AX5
   INT TQ_AX6
   IF $IMPROVED_COLLMON == TRUE THEN
      ON_ERROR_PROCEED
      $COLLMON_TOL_PRO[1]=TQ_AX1
      IF $ERR.NUMBER == 0 THEN
         $COLLMON_TOL_PRO[2]=TQ_AX2
         $COLLMON_TOL_PRO[3]=TQ_AX3
         $COLLMON_TOL_PRO[4]=TQ_AX4
         $COLLMON_TOL_PRO[5]=TQ_AX5
         $COLLMON_TOL_PRO[6]=TQ_AX6
      ELSE
         FOR I = 1 TO 12
            $COLLMON_TOL_PRO[I]=$COLLMON_TOL_PRO_DEF[I]
         ENDFOR
         ERR_CLEAR($ERR)
      ENDIF
      FOR I = 1 TO 12
         COLLMON_TOL_PRO[I]=$COLLMON_TOL_PRO[I]
      ENDFOR
      COLLMON_IDX=0
      $COLLMON_IDX=0
   ELSE
      ON_ERROR_PROCEED
      $TORQMON[1]=TQ_AX1
      IF $ERR.NUMBER == 0 THEN
         $TORQMON[2]=TQ_AX2
         $TORQMON[3]=TQ_AX3
         $TORQMON[4]=TQ_AX4
         $TORQMON[5]=TQ_AX5
         $TORQMON[6]=TQ_AX6
      ELSE
         FOR I = 1 TO 12
            $TORQMON[I]=$TORQMON_DEF[I]
         ENDFOR
         ERR_CLEAR($ERR)
      ENDIF
   ENDIF
END